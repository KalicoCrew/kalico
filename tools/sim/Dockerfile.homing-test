FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# System deps + ARM cross-compiler
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv python3-dev python3-cffi \
    gcc g++ make git socat netcat-openbsd curl ca-certificates \
    libffi-dev pkg-config xz-utils libudev-dev libicu-dev \
    gcc-arm-none-eabi libnewlib-arm-none-eabi && \
    rm -rf /var/lib/apt/lists/*

# Renode (ARM64 portable with bundled .NET)
RUN curl -sL https://github.com/renode/renode/releases/download/v1.16.1/renode-1.16.1.linux-arm64-portable-dotnet.tar.gz \
    -o /tmp/renode.tar.gz && \
    mkdir -p /opt/renode && \
    tar xzf /tmp/renode.tar.gz -C /opt/renode --strip-components=1 && \
    rm /tmp/renode.tar.gz && \
    ln -s /opt/renode/renode /usr/local/bin/renode

# Rust
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | \
    sh -s -- -y --default-toolchain stable
ENV PATH="/root/.cargo/bin:${PATH}"
RUN rustup target add thumbv7em-none-eabi

# Python deps
RUN pip3 install --break-system-packages cffi pyserial greenlet jinja2 numpy

# Source — one big COPY, but the heavy layers above are cached.
WORKDIR /work
COPY . /work/

# Build H7 sim firmware
RUN cp tools/sim/sim.config .config && \
    make olddefconfig && \
    if grep -q '^CONFIG_STACK_SIZE=' tools/sim/sim.config; then \
      STACK_OVERRIDE=$(grep '^CONFIG_STACK_SIZE=' tools/sim/sim.config | head -n1) && \
      sed -i "s|^CONFIG_STACK_SIZE=.*|${STACK_OVERRIDE}|" .config && \
      touch .config && rm -f out/autoconf.h; \
    fi && \
    make clean && \
    make -j$(nproc) && \
    cp out/klipper.elf /tmp/klipper-h7-sim.elf

# Build F446 sim firmware
RUN cp tools/sim/sim_f446.config .config && \
    make olddefconfig && \
    make clean && \
    make -j$(nproc) && \
    cp out/klipper.elf out/klipper-f4-sim.elf && \
    cp /tmp/klipper-h7-sim.elf out/klipper-h7-sim.elf

# Build motion-bridge for host (Linux)
RUN cd rust && cargo build -p motion-bridge --release && \
    cp target/release/libmotion_bridge_native.so ../klippy/motion_bridge_native.so

# Remove stale chelper (will be auto-built on first klippy start)
RUN rm -f klippy/chelper/c_helper.so

CMD ["/work/tools/sim/docker_homing_test.sh"]
