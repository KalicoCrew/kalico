choice
    prompt "Runtime sizing profile"
    default RUNTIME_TARGET_LARGE if MACH_STM32H7
    default RUNTIME_TARGET_SMALL if MACH_STM32F4
    default RUNTIME_TARGET_LARGE
    depends on MACH_STM32H7 || MACH_STM32F4 || MACH_LINUX
    help
      Selects per-MCU runtime sizing presets. `large` is the H7-class
      profile that places the curve pool in AXI SRAM. `small` is the
      F4-class profile that fits in 128 KB SRAM. `custom` lets you
      override individual values below.

    config RUNTIME_TARGET_LARGE
        bool "Large (H7-class — fits in AXI SRAM)"

    config RUNTIME_TARGET_SMALL
        bool "Small (F4-class — fits in 128 KB SRAM)"

    config RUNTIME_TARGET_CUSTOM
        bool "Custom (override individual values)"
endchoice

config RUNTIME_CURVE_POOL_N
    int "Curve-pool slot count (planner look-ahead depth)"
    default 16 if RUNTIME_TARGET_LARGE
    default 4 if RUNTIME_TARGET_SMALL
    default 4
    range 1 64

config RUNTIME_MAX_PIECES_PER_CURVE
    int "Maximum cubic Bézier pieces per curve slot"
    default 16
    range 1 64
    help
      Per-slot ceiling on cubic Bézier pieces. Both `RUNTIME_CURVE_POOL_N`
      and this value back the static cubic piece pool: total storage is
      `CURVE_POOL_N * MAX_PIECES_PER_CURVE * sizeof(BezierPieceMonomial)`.
      Reported to the host via `RuntimeCapsResponse.max_pieces_per_curve`;
      the host's pre-upload validator rejects curves whose piece count
      exceeds this value. Default 16 matches the Rust runtime's compile
      time `MAX_PIECES_PER_CURVE`.

config KALICO_MOTION_SAMPLE_RATE_HZ
    int "Motion engine sample rate in Hz (TIM5 ISR fire rate)"
    depends on MACH_STM32H7 || MACH_STM32F4 || MACH_LINUX
    default 40000 if MACH_STM32H7
    default 20000 if MACH_STM32F4
    default 10000
    range 1000 100000
    help
      Rate at which the TIM5 ISR evaluates motion curves and emits step
      pulses. Higher rates give better velocity-extrapolation accuracy
      but cost more CPU. Defaults to 40 kHz on H7 (520 MHz) and 20 kHz
      on F4 (180 MHz); see docs/superpowers/specs/2026-05-19-stepping-
      redesign-design.md for the per-MCU step-rate ceilings these
      enable.

config RUNTIME_STORAGE_SIZE_LARGE
    int "rt_storage byte ceiling (large profile, H7)"
    default 63488
    range 65536 524288
    help
      Byte ceiling for rt_storage (the C-declared backing buffer that
      replaces RT_CELL's Rust-side #[link_section] placement). Task 18
      measured size_of::<RuntimeContext>() = 59048 bytes (57 KB) after
      the 2026-05-20 stepping redesign replaced the NURBS curve pool
      (~298 KB on LARGE) with a uniform cubic Bézier piece pool (~8 KB
      at CURVE_POOL_N=16). Default is 63488 bytes (62 KB), providing
      4440 bytes of headroom. The AXI SRAM ceiling on H7 is 320 KB;
      the C-side _Static_assert in src/runtime_storage.c enforces 2 KB
      headroom. The Rust-side const_assert fires if RuntimeContext
      exceeds this value at compile time.

config RUNTIME_STORAGE_SIZE_SMALL
    int "rt_storage byte ceiling (small profile, F4)"
    default 63488
    range 32768 131072
    help
      Byte ceiling for rt_storage (the C-declared backing buffer that
      replaces RT_CELL's Rust-side #[link_section] placement). Task 18
      measured size_of::<RuntimeContext>() = 59048 bytes (57 KB) after
      the 2026-05-20 stepping redesign replaced the NURBS curve pool
      (~103 KB on SMALL) with a uniform cubic Bézier piece pool (~4 KB
      at CURVE_POOL_N=4). Default is 63488 bytes (62 KB) — the same as
      LARGE because the measured size is identical and well below the F4
      SRAM cap; no separate profile needed. Provides 4440 bytes of
      headroom. F4's total SRAM is 128 KB; a 62 KB rt_storage leaves
      ~66 KB for Klipper's .bss + stack + heap, which is ample.
      Const_assert on Rust catches RuntimeContext growth at compile
      time.

config KALICO_SIM
    bool "Build for simulator (disables IWDG, enables Linux sim shims)"
    default n
    help
      Builds a sim-flavor image: skips watchdog_init / watchdog_reset
      so Renode's IWDG model can't trigger spurious resets, and (on
      MACH_LINUX) replaces real /dev/gpiochip / /dev/spidev / /sys/iio
      / /sys/class/pwm access with in-memory stubs and Unix-socket
      passthroughs to chip emulators. NEVER enable for a flashed-to-
      silicon build — it leaves the IWDG effectively off, which is
      unsafe on real hardware.

config KALICO_SIM_TMCUART_BYPASS
    bool "Bypass tmcuart bit-bang and write bytes to a Unix socket"
    depends on MACH_LINUX
    default n
    help
      Sim-only escape hatch for the tmcuart driver. When enabled, the
      tmcuart_send command bypasses the GPIO bit-bang and writes raw
      bytes directly to ${KALICO_SIM_SOCK_DIR}/tmcuart_<oid>. This is
      the one architectural exception to the otherwise-clean
      "production firmware knows nothing about sim" rule for MACH_LINUX
      builds — the bit-bang's timing fragility under Linux scheduler
      jitter would make a shim-side decoder flake intermittently. See
      docs/superpowers/specs/2026-05-08-syscall-shim-design.md
      §"Chip emulator routing → tmcuart" for rationale.

config RUNTIME_BENCH
    bool "Cycle-count benchmark for runtime tick"
    depends on MACH_STM32H7
    default y if MACH_STM32H7
    help
      Captures per-tick cycle counts for performance regression tracking.
      Enabled by default on H7. F4 / host targets do not currently provide
      a cycle counter suitable for bench; left unselected.

source "src/extras/Kconfig"
