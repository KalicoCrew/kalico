FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone
RUN mkdir /ci_build

# Install dependencies. No MCU cross-toolchains here: the only supported
# firmware is the kalico motion-runtime firmware (H723/F446/G0B1 + Linux
# MCU), which needs the Rust toolchain and is built+linked by the dedicated
# ci-mcu-firmware.yaml workflow. This image only runs the klippy host-side
# python suite (build-essential covers chelper / test shim C builds).
RUN apt update \
    && apt install -y sudo git curl \
      python3 python3-dev python3-venv libffi-dev build-essential \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

COPY . /klipper
WORKDIR /klipper

ENV DICTDIR=/ci_build/dict
RUN uv run ./scripts/ci-build.sh

ENTRYPOINT [ "/bin/uv", "run" ]
CMD [ "py.test" ]
