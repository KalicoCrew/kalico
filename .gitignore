.vscode
.idea/*

# docs
site/
.env/
.venv/
env/
venv/
mkdocs-env/

# fitter prototype run outputs
scripts/fitter_prototype/corpus_results/

# git worktrees
.worktrees/

# claude-code session-local runtime state (lock file holds session pid +
# acquired-at; the rest of .claude/ — plugins, skills, settings — IS tracked)
.claude/scheduled_tasks.lock

# Built artifacts (motion-bridge .so, chelper .so) — built per-platform,
# never checked in. Keep klippy/ clean across macOS/Linux/Pi dev.
klippy/motion_bridge*.so
klippy/motion_bridge*.dylib
klippy/chelper/c_helper.so
klippy/chelper/c_helper.so.dSYM/
klippy/chelper/*.dylib

# Sim-only third-party plugin symlinks (created by tools/sim_klippy/conftest.py)
klippy/extras/beacon.py
klippy/extras/motors_sync.py
klippy/extras/autotune_tmc.py
klippy/extras/motor_constants.py

# Third-party plugin sources (fetched on demand by tools/sim_klippy/fetch_plugins.sh)
tools/sim_klippy/printer_real/third_party_repos/
