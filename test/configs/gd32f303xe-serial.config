CONFIG_BOARD_DIRECTORY="gd32"
CONFIG_MCU="gd32f303xe"
CONFIG_CLOCK_FREQ=120000000
CONFIG_SERIAL=y
CONFIG_FLASH_SIZE=0x80000
CONFIG_FLASH_BOOT_ADDRESS=0x8000000
CONFIG_RAM_START=0x20000000
CONFIG_RAM_SIZE=0x10000
CONFIG_STACK_SIZE=512
CONFIG_FLASH_APPLICATION_ADDRESS=0x8002000
CONFIG_CLOCK_REF_FREQ=8000000
CONFIG_GD32_SELECT=y
# CONFIG_MACH_GD32F303XB is not set
# CONFIG_MACH_GD32F303XC is not set
CONFIG_MACH_GD32F303XE=y
# CONFIG_MACH_GD32F303XG is not set
# CONFIG_MACH_GD32F303XI is not set
# CONFIG_MACH_GD32F303XK is not set
