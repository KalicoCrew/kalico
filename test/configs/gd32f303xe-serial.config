# CONFIG_MACH_GD32E230X4 is not set
# CONFIG_MACH_GD32E230X6 is not set
# CONFIG_MACH_GD32E230X8 is not set
# CONFIG_MACH_GD32E231X6 is not set
# CONFIG_MACH_GD32E231X8 is not set
CONFIG_MACH_GD32F30X_HD=y
CONFIG_MACH_GD32F30X=y
CONFIG_GD32_FLASH_START_2000=y
# CONFIG_GD32_FLASH_START_5000 is not set
# CONFIG_GD32_FLASH_START_8000 is not set
# CONFIG_GD32_FLASH_START_800 is not set
# CONFIG_GD32_FLASH_START_1000 is not set
