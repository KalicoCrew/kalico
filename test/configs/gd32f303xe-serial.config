# CONFIG_GD32_SERIAL_USART3 is not set
# CONFIG_GD32_SERIAL_USART3_ALT_PD9_PD8 is not set
CONFIG_SERIAL_BAUD=250000
CONFIG_USB_VENDOR_ID=0x1d50
CONFIG_USB_DEVICE_ID=0x614e
CONFIG_USB_SERIAL_NUMBER="12345"
CONFIG_USB_MANUFACTURER="Klipper"
CONFIG_CAN_UUID_CUSTOM="abc1234"
CONFIG_WANT_ADC=y
CONFIG_WANT_SPI=y
CONFIG_WANT_SOFTWARE_SPI=y
CONFIG_WANT_I2C=y
