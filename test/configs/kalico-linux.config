# Kalico first-class Linux MCU (MACH_LINUX, real hardware — NO kalico-sim).
# Real /dev/gpiochip / /dev/spidev / /sys/iio access; stepper dispatch on.
# This is the canonical real-hardware Linux MCU build and the CI link-coverage
# target (it resolves the C step/SPI FFI against linux/phase_stepping_spi.c with
# the `mcu-linux` Rust feature, kalico-sim absent).
#
# The SIM counterpart is .config.linux (CONFIG_KALICO_SIM=y), used by
# tools/sim_klippy.
CONFIG_LOW_LEVEL_OPTIONS=y
CONFIG_MACH_LINUX=y
CONFIG_LINUX_SELECT=y
# CONFIG_KALICO_SIM is not set
CONFIG_MOTION_MODULE_STEPPER=y
CONFIG_BOARD_DIRECTORY="linux"
CONFIG_CLOCK_FREQ=50000000
CONFIG_USB=n
CONFIG_USBSERIAL=n
CONFIG_SERIAL=n
CONFIG_WANT_GPIO_BITBANGING=y
CONFIG_WANT_DISPLAYS=y
CONFIG_WANT_SENSORS=y
CONFIG_WANT_LIS2DW=y
CONFIG_WANT_LDC1612=y
CONFIG_WANT_SOFTWARE_I2C=y
CONFIG_WANT_SOFTWARE_SPI=y
CONFIG_HAVE_GPIO=y
CONFIG_HAVE_GPIO_ADC=y
CONFIG_HAVE_GPIO_SPI=y
CONFIG_HAVE_GPIO_I2C=y
CONFIG_HAVE_GPIO_HARD_PWM=y
CONFIG_INLINE_STEPPER_HACK=y
