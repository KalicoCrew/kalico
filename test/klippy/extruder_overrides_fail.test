# Extruder override failure tests
DICTIONARY atmega2560.dict
CONFIG extruder_overrides_fail.cfg

# Test that values outside override bounds fail
# Test pressure advance below min override (should fail)
SET_PRESSURE_ADVANCE EXTRUDER=extruder ADVANCE=-0.1

# Test pressure advance above max override (should fail)
SET_PRESSURE_ADVANCE EXTRUDER=extruder ADVANCE=3.0

# Test pressure advance smooth_time below min override (should fail)
SET_PRESSURE_ADVANCE EXTRUDER=extruder ADVANCE=0.025 SMOOTH_TIME=-0.1

# Test pressure advance smooth_time above max override (should fail)
SET_PRESSURE_ADVANCE EXTRUDER=extruder ADVANCE=0.025 SMOOTH_TIME=2.0

# Test normal operation within bounds
SET_PRESSURE_ADVANCE EXTRUDER=extruder ADVANCE=0.025 SMOOTH_TIME=0.040

G28
G1 X10 Y10 Z5 E5
