# Extruder default behavior tests (no overrides)
DICTIONARY atmega2560.dict
CONFIG extruder_defaults.cfg

# Test that original limits still work without overrides
# Test pressure advance smooth_time at original max (0.200) - should work
SET_PRESSURE_ADVANCE EXTRUDER=extruder ADVANCE=0.025 SMOOTH_TIME=0.200

# Test pressure advance smooth_time above original max (0.300) - should fail
SET_PRESSURE_ADVANCE EXTRUDER=extruder ADVANCE=0.025 SMOOTH_TIME=0.300

# Test pressure advance below min (negative) - should fail
SET_PRESSURE_ADVANCE EXTRUDER=extruder ADVANCE=-0.1

# Test normal operation
SET_PRESSURE_ADVANCE EXTRUDER=extruder ADVANCE=0.025 SMOOTH_TIME=0.040

G28
G1 X10 Y10 Z5 E5

# Test extruder config with default limits
# max_extrude_only_distance default is 50.0 - this should work in config
SET_EXTRUDER_ROTATION_DISTANCE EXTRUDER=extruder DISTANCE=33.5

G1 X20 Y20 Z10 E10
